# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Gemini API key — required for density lookup and recipe generation
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model used for both density lookup (stage ③) and recipe generation (stage ⑤).
# Change this to test different models without touching the code.
GEMINI_MODEL=gemini-3.1-flash-lite
